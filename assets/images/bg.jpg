<svg xmlns="http://www.w3.org/2000/svg" width="1920" height="1080" viewBox="0 0 1920 1080">
  <defs>
    <linearGradient id="bg1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0f172a;stop-opacity:1" />
      <stop offset="30%" style="stop-color:#1e1b4b;stop-opacity:1" />
      <stop offset="60%" style="stop-color:#312e81;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#4c1d95;stop-opacity:1" />
    </linearGradient>
    <radialGradient id="glow1" cx="20%" cy="30%" r="40%">
      <stop offset="0%" style="stop-color:#6366f1;stop-opacity:0.3"/>
      <stop offset="100%" style="stop-color:#6366f1;stop-opacity:0"/>
    </radialGradient>
    <radialGradient id="glow2" cx="80%" cy="70%" r="35%">
      <stop offset="0%" style="stop-color:#ec4899;stop-opacity:0.15"/>
      <stop offset="100%" style="stop-color:#ec4899;stop-opacity:0"/>
    </radialGradient>
    <pattern id="dots" width="60" height="60" patternUnits="userSpaceOnUse">
      <circle cx="30" cy="30" r="1.5" fill="white" opacity="0.07"/>
    </pattern>
  </defs>

  <!-- 基础渐变背景 -->
  <rect width="1920" height="1080" fill="url(#bg1)"/>

  <!-- 光斑效果 -->
  <rect width="1920" height="1080" fill="url(#glow1)"/>
  <rect width="1920" height="1080" fill="url(#glow2)"/>

  <!-- 点阵图案 -->
  <rect width="1920" height="1080" fill="url(#dots)"/>

  <!-- 几何装饰 -->
  <circle cx="1600" cy="250" r="200" fill="none" stroke="#818cf8" stroke-width="1" opacity="0.1"/>
  <circle cx="1600" cy="250" r="150" fill="none" stroke="#a78bfa" stroke-width="1" opacity="0.08"/>
  <polygon points="300,800 400,650 500,800 450,900 350,900" fill="none" stroke="#ec4899" stroke-width="1" opacity="0.08"/>

  <!-- 网格线 -->
  <line x1="0" y1="540" x2="1920" y2="540" stroke="#6366f1" stroke-width="0.5" opacity="0.06"/>
  <line x1="960" y1="0" x2="960" y2="1080" stroke="#6366f1" stroke-width="0.5" opacity="0.06"/>
</svg>
